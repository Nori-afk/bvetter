# .env.example — copy to .env and fill in real values; never commit .env

DB_HOST=127.0.0.1
DB_PORT=3307
DB_NAME=bvetter
DB_USER=root
DB_PASS=

# Same DB, read by api/analytics/arima_service.py (Python has no shared PDO
# connection with the PHP layer, so its credentials are repeated here).
VBETTER_DB_HOST=127.0.0.1
VBETTER_DB_PORT=3307
VBETTER_DB_USER=root
VBETTER_DB_PASS=
VBETTER_DB_NAME=bvetter

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

SEMAPHORE_API_KEY=
SEMAPHORE_SENDER_NAME=VBETTER

APP_ENV=production
APP_DEBUG=false
APP_BASE_URL=http://localhost/bvetter

VBETTER_ANALYTICS_URL=http://127.0.0.1:5001
