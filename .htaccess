Options -Indexes
ServerSignature Off

# Deny access to sensitive files
<FilesMatch "(\.env|\.git|composer\.phar|composer-setup\.php|bvetter\.sql|reset-links\.log)">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block PHP execution inside storage (prevent uploaded PHP files from running).
# Static files (images, PDFs) are intentionally served directly — the frontend
# references them as /bvetter/storage/... URLs in <img> src attributes.
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^storage/.*\.(php[0-9]?|phtml|phar)$ - [F,L]
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
